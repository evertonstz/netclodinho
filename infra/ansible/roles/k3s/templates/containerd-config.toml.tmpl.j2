# containerd config template for k3s with Kata runtime
# Managed by Ansible - do not edit manually
#
# Uses containerd v2 CRI plugin path (io.containerd.cri.v1.runtime)

version = 2

[plugins."io.containerd.cri.v1.runtime"]
  [plugins."io.containerd.cri.v1.runtime".cni]
    # Hardcoded paths since --flannel-backend=none doesn't set these
    bin_dir = "/opt/cni/bin"
    conf_dir = "/etc/cni/net.d"

  [plugins."io.containerd.cri.v1.runtime".containerd]
    default_runtime_name = "runc"

    [plugins."io.containerd.cri.v1.runtime".containerd.runtimes.runc]
      runtime_type = "io.containerd.runc.v2"

    [plugins."io.containerd.cri.v1.runtime".containerd.runtimes.kata-clh]
      runtime_type = "io.containerd.kata-clh.v2"
      privileged_without_host_devices = true
      pod_annotations = ["io.katacontainers.*"]
      [plugins."io.containerd.cri.v1.runtime".containerd.runtimes.kata-clh.options]
        ConfigPath = "{{ kata_dir }}/share/defaults/kata-containers/configuration-clh.toml"

{% if nvidia_enabled | default(false) %}
    # NVIDIA runtime for GPU workloads (e.g., Ollama)
    [plugins."io.containerd.cri.v1.runtime".containerd.runtimes.nvidia]
      runtime_type = "io.containerd.runc.v2"
      privileged_without_host_devices = false
      [plugins."io.containerd.cri.v1.runtime".containerd.runtimes.nvidia.options]
        BinaryName = "/usr/bin/nvidia-container-runtime"
{% endif %}
