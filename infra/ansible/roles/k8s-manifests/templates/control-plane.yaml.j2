# Control Plane Deployment
apiVersion: apps/v1
kind: Deployment
metadata:
  name: control-plane
  namespace: netclode
  labels:
    app: control-plane
spec:
  replicas: 1
  selector:
    matchLabels:
      app: control-plane
  template:
    metadata:
      labels:
        app: control-plane
{% if dd_api_key | default('') | length > 0 %}
      annotations:
        ad.datadoghq.com/control-plane.logs: '[{"source": "go", "service": "control-plane"}]'
{% endif %}
    spec:
      serviceAccountName: control-plane
      containers:
        - name: control-plane
          image: ghcr.io/evertonstz/netclode-control-plane:latest
          ports:
            - containerPort: 3000
              name: http
          env:
            - name: PORT
              value: "3000"
            - name: K8S_NAMESPACE
              valueFrom:
                fieldRef:
                  fieldPath: metadata.namespace
            - name: ANTHROPIC_API_KEY
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: anthropic-api-key
            - name: GITHUB_COPILOT_TOKEN
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: github-copilot-token
                  optional: true
            - name: GITHUB_COPILOT_OAUTH_ACCESS_TOKEN
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: github-copilot-oauth-access-token
                  optional: true
            - name: GITHUB_COPILOT_OAUTH_REFRESH_TOKEN
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: github-copilot-oauth-refresh-token
                  optional: true
            - name: GITHUB_COPILOT_OAUTH_TOKEN_EXPIRES
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: github-copilot-oauth-token-expires
                  optional: true
            # GitHub App integration (optional)
            - name: GITHUB_APP_ID
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: github-app-id
                  optional: true
            - name: GITHUB_APP_PRIVATE_KEY
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: github-app-private-key
                  optional: true
            - name: GITHUB_INSTALLATION_ID
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: github-installation-id
                  optional: true
            - name: OPENAI_API_KEY
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: openai-api-key
                  optional: true
            - name: CODEX_ACCESS_TOKEN
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: codex-access-token
                  optional: true
            - name: CODEX_ID_TOKEN
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: codex-id-token
                  optional: true
            - name: CODEX_REFRESH_TOKEN
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: codex-refresh-token
                  optional: true
            - name: MISTRAL_API_KEY
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: mistral-api-key
                  optional: true
            # OpenCode Zen API key (optional - for paid Zen models)
            - name: OPENCODE_API_KEY
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: opencode-api-key
                  optional: true
            # Z.AI API key (optional - for GLM-4.7 models)
            - name: ZAI_API_KEY
              valueFrom:
                secretKeyRef:
                  name: netclode-secrets
                  key: zai-api-key
                  optional: true
            # Ollama local inference (optional - only set if ollama_enabled)
{% if ollama_enabled | default(false) %}
            - name: OLLAMA_URL
              value: "http://ollama.netclode.svc.cluster.local:11434"
{% endif %}
            - name: REDIS_URL
              value: "redis://redis-sessions.netclode.svc.cluster.local:6379"
            - name: WARM_POOL_ENABLED
              value: "true"
            - name: MAX_ACTIVE_SESSIONS
              value: "{{ max_active_sessions | default('5') }}"
            - name: IDLE_TIMEOUT_MINUTES
              value: "{{ idle_timeout_minutes | default('0') }}"
            # Host resources (used to derive per-session limits: CPU 50%, Memory 25%)
            - name: HOST_CPUS
              value: "{{ ansible_processor_vcpus }}"
            - name: HOST_MEMORY_MB
              value: "{{ ansible_memtotal_mb }}"
            # Overcommit ratios for K8s scheduling (requests = actual / ratio)
            # Higher ratio = more pods can be scheduled. Kata VMs still get full resources.
            - name: CPU_OVERCOMMIT_RATIO
              value: "{{ cpu_overcommit_ratio | default('4') }}"
            - name: MEMORY_OVERCOMMIT_RATIO
              value: "{{ memory_overcommit_ratio | default('4') }}"
{% if dd_api_key | default('') | length > 0 %}
            # Datadog APM + Observability
            - name: DD_ENV
              value: "production"
            - name: DD_SERVICE
              value: "control-plane"
            - name: DD_VERSION
              value: "{{ dd_version }}"
            - name: DD_AGENT_HOST
              valueFrom:
                fieldRef:
                  fieldPath: status.hostIP
            - name: DD_TRACE_AGENT_PORT
              value: "8126"
            - name: DD_DOGSTATSD_PORT
              value: "8125"
            - name: DD_LOGS_INJECTION
              value: "true"
            - name: DD_RUNTIME_METRICS_ENABLED
              value: "true"
            - name: DD_PROFILING_ENABLED
              value: "true"
            - name: DD_GIT_REPOSITORY_URL
              value: "https://github.com/angristan/netclode"
            - name: DD_GIT_COMMIT_SHA
              value: "{{ dd_git_commit_sha }}"
{% endif %}
          readinessProbe:
            httpGet:
              path: /health
              port: 3000
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /health
              port: 3000
            initialDelaySeconds: 15
            periodSeconds: 20
---
# Control Plane Service
apiVersion: v1
kind: Service
metadata:
  name: control-plane
  namespace: netclode
  labels:
    app: control-plane
spec:
  type: ClusterIP
  selector:
    app: control-plane
  ports:
    - port: 80
      targetPort: 3000
      name: http
# Note: iOS clients connect via Tailscale Ingress (see control-plane-ingress.yaml)
# Internal agents connect via h2c on this service (port 80)
