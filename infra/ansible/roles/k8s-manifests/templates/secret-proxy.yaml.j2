# Secret Proxy Deployment
# Runs OUTSIDE Kata VMs - secrets never enter the sandbox microVM.
# Validates each request with control-plane for per-session authorization.
apiVersion: apps/v1
kind: Deployment
metadata:
  name: secret-proxy
  namespace: netclode
  labels:
    app: secret-proxy
spec:
  replicas: 1
  selector:
    matchLabels:
      app: secret-proxy
  template:
    metadata:
      labels:
        app: secret-proxy
    spec:
      containers:
        - name: secret-proxy
          image: ghcr.io/angristan/netclode-secret-proxy:latest
          imagePullPolicy: Always
          securityContext:
            runAsUser: 65534  # nobody
            runAsGroup: 65534
            readOnlyRootFilesystem: true
          env:
            - name: LISTEN_ADDR
              value: ":8080"
            - name: CONTROL_PLANE_URL
              value: "http://control-plane.netclode.svc.cluster.local"
            - name: CA_CERT_PATH
              value: "/etc/secret-proxy/ca.crt"
            - name: CA_KEY_PATH
              value: "/etc/secret-proxy/ca.key"
            - name: SECRETS_PATH
              value: "/etc/secret-proxy/secrets.json"
          volumeMounts:
            - name: proxy-ca
              mountPath: /etc/secret-proxy/ca.crt
              subPath: ca.crt
              readOnly: true
            - name: proxy-ca-key
              mountPath: /etc/secret-proxy/ca.key
              subPath: ca.key
              readOnly: true
            - name: secrets
              mountPath: /etc/secret-proxy/secrets.json
              subPath: secrets.json
              readOnly: true
          ports:
            - containerPort: 8080
              name: proxy
          resources:
            requests:
              cpu: "50m"
              memory: "32Mi"
            limits:
              cpu: "500m"
              memory: "128Mi"
          readinessProbe:
            tcpSocket:
              port: 8080
            initialDelaySeconds: 2
            periodSeconds: 5
          livenessProbe:
            tcpSocket:
              port: 8080
            initialDelaySeconds: 10
            periodSeconds: 10
      volumes:
        - name: proxy-ca
          configMap:
            name: secret-proxy-ca
        - name: proxy-ca-key
          secret:
            secretName: secret-proxy-ca-key
        - name: secrets
          secret:
            secretName: secret-proxy-secrets
---
# Secret Proxy Service
apiVersion: v1
kind: Service
metadata:
  name: secret-proxy
  namespace: netclode
  labels:
    app: secret-proxy
spec:
  type: ClusterIP
  selector:
    app: secret-proxy
  ports:
    - port: 8080
      targetPort: 8080
      name: proxy
