{
  "name": "@netclode/agent",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/agent.js",
    "start": "node dist/agent.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome lint src/",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.42",
    "@anthropic-ai/sdk": "^0.74.0",
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-node": "^2.1.1",
    "@earendil-works/pi-agent-core": "^0.75.4",
    "@github/copilot-sdk": "^0.1.23",
    "@openai/codex-sdk": "^0.101.0",
    "@opencode-ai/sdk": "^1.15.5",
    "node-pty": "^1.0.0",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@bufbuild/protoplugin": "^2.12.0",
    "@types/node": "^25.2.3",
    "esbuild": "^0.27.3",
    "tsx": "^4.22.3",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
