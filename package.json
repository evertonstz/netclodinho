{
  "name": "netclode",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:agent": "npm run dev --workspace=@netclode/agent",
    "dev:web": "npm run dev --workspace=@netclode/web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
